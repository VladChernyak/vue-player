{
  "name": "@vue-player/nuxt",
  "version": "0.1.1",
  "description": "Official Nuxt 3 module for vue-player — auto-imports VideoPlayer and usePlayer",
  "keywords": [
    "nuxt",
    "nuxt3",
    "nuxt-module",
    "vue",
    "vue3",
    "video",
    "video-player",
    "player",
    "hls",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://vue-player.vercel.app/guide/nuxt",
  "bugs": {
    "url": "https://github.com/VladChernyak/vue-player/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs",
      "types": "./dist/module.d.ts"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/module.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "dependencies": {
    "@nuxt/kit": "^3.16.0",
    "@vue-player/vue": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/schema": "^3.16.0"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VladChernyak/vue-player",
    "directory": "packages/nuxt"
  }
}
