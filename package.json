{
  "name": "vue-player",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "playground": "pnpm --filter @vue-player/playground-vue dev",
    "docs:dev": "pnpm --filter @vue-player/docs dev",
    "docs:build": "pnpm --filter @vue-player/docs build",
    "docs:preview": "pnpm --filter @vue-player/docs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "unbuild": "^3.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.2.7"
  }
}
