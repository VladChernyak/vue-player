{
  "name": "@vue-player/vue",
  "version": "0.1.3",
  "description": "Feature-rich Vue 3 video player with HLS streaming, subtitles, chapters and thumbnail previews",
  "keywords": [
    "vue",
    "vue3",
    "video",
    "video-player",
    "player",
    "hls",
    "hls.js",
    "adaptive-streaming",
    "subtitles",
    "chapters",
    "thumbnails",
    "composable",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://vue-player.vercel.app",
  "bugs": {
    "url": "https://github.com/VladChernyak/vue-player/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "unbuild --stub"
  },
  "dependencies": {
    "@vue-player/core": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "hls.js": "^1.5.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^5.0.0"
  },
  "peerDependencies": {
    "hls.js": ">=1.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VladChernyak/vue-player",
    "directory": "packages/vue"
  }
}
